extends ../../layouts/default.pug
include ../../mixins/alert.pug

block main
  .container-fluid.mt-4

    +alertSuccess(3000)
    +alertError(3000)

    // ===== HEADER =====
    .d-flex.justify-content-between.align-items-center.mb-3
      h3.mb-0 Chi tiết sản phẩm
      a.btn.btn-secondary(href=`${prefixAdmin}/products`) ← Quay lại

    // ===== CARD DETAIL =====
    .card.shadow-sm
      .card-body

        .row

          // ===== ẢNH =====
          .col-md-4.text-center
            if product.thumbnail
              img(
                src=product.thumbnail
                alt=product.title
                style="width: 100%; max-width: 300px; object-fit: cover; border-radius: 8px;"
              )
            else
              img(
                src="/images/no-image.png"
                style="width: 100%; max-width: 300px;"
              )

          // ===== THÔNG TIN =====
          .col-md-8

            h4.mb-3 #{product.title}

            p
              strong Giá:
              span.text-danger.fw-bold.ms-2 #{product.price}$

            p
              strong Giảm giá:
              span.ms-2 #{product.discountPercentage || 0} %

            p
              strong Số lượng:
              span.ms-2 #{product.stock || 0}

            p
              strong Vị trí:
              span.ms-2 #{product.position}

            p
              strong Trạng thái:
              if product.status == "active"
                span.badge.bg-success.ms-2 Hoạt động
              else
                span.badge.bg-danger.ms-2 Dừng hoạt động

            p
              strong Ngày tạo:
              span.ms-2 #{product.createdAt}

        hr

        // ===== MÔ TẢ =====
        h5 Mô tả sản phẩm
        if product.description
          p.text-muted #{product.description}
        else
          p.text-muted Chưa có mô tả

        hr

        // ===== ACTION =====
        .text-end
          a.btn.btn-warning.me-2(
            href=`${prefixAdmin}/products/edit/${product._id}`
          ) Sửa

          a.btn.btn-danger(
            href="#"
          ) Xóa